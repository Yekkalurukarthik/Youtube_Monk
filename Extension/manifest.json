{
    "manifest_version": 3,
    "name": "Youtube Monk",
    "version": "1.0",
    "description": "Hide distratciton on Youtube",
    "permissions": [
        "storage",
        "tabs"
    ],
    "background": {
        "service_worker": "background.js"
    }, 
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.youtube.com/*",
                  "http://localhost:5173/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}